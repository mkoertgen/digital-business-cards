# Copy to .env.ldap and fill in your values.
# Used by: dbc sync --source ldap

LDAP_URL=ldap://localhost
LDAP_BIND_DN=cn=admin,dc=acme,dc=example
LDAP_BIND_PASSWORD=admin
LDAP_BASE_DN=dc=acme,dc=example

# For LDAPS (TLS):
# LDAP_URL=ldaps://dc.example.com
# LDAP_BIND_DN=CN=svc-dbc,OU=ServiceAccounts,DC=example,DC=com
# LDAP_BIND_PASSWORD=<password>
# LDAP_BASE_DN=DC=example,DC=com

# Auth type: simple (default), ntlm, anonymous
# LDAP_AUTH=simple
