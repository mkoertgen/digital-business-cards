{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "description": "Automated dependency updates for digital-business-cards",
  "enabledManagers": ["github-actions", "uv"],
  "packageRules": [
    {
      "description": "Group and automerge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group all Python dependency updates",
      "matchManagers": ["uv"],
      "groupName": "Python dependencies"
    }
  ],
  "labels": ["dependencies", "renovate"],
  "prConcurrentLimit": 3
}
